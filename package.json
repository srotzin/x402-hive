{
  "name": "x402-hive",
  "version": "0.1.0",
  "description": "Drop-in x402 adapter that emits a Hive HAHS receipt and SpectralZK sidecar for every x402 payment. Makes any x402 facilitator audit-ready without changing your payment flow.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "test": "node --test --import tsx test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["x402", "agent", "settlement", "audit", "hive", "stablecoin", "payment"],
  "author": "Hive Civilization <sales@thehiveryiq.com>",
  "license": "MIT",
  "engines": { "node": ">=20" },
  "dependencies": {
    "@hive-protocol/sdk": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "homepage": "https://thehiveryiq.com/sdk/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srotzin/x402-hive.git"
  }
}
